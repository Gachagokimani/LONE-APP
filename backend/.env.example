# Django Development Settings
DEBUG=True
DEVELOPMENT_MODE=True
SECRET_KEY=django-insecure-dev-only-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (SQLite by default, override with DATABASE_URL for PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/loanapp

# JWT Settings (in hours for access, days for refresh)
# ACCESS_TOKEN_LIFETIME=1
# REFRESH_TOKEN_LIFETIME=1

# N8N Webhook (optional, set to your n8n instance)
# N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook/
